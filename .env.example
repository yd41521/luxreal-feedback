# 飞书企业自建应用（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格（必填）
FEISHU_APP_TOKEN=AAA_BitableAppTokenFromUrl
FEISHU_TABLE_ITEMS=tblXxxxxxxxxxxxx
FEISHU_TABLE_VOTES=tblYyyyyyyyyyyyy

# Upstash Redis 限频（可选；未配置时用本地内存兜底，仅适合单机）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 允许的来源（逗号分隔），用于 Origin 校验
ALLOWED_ORIGINS=http://localhost:3000,https://feedback.luxreal.com,https://www.luxreal.com

# 公共配置
NEXT_PUBLIC_SITE_NAME=LuxReal
NEXT_PUBLIC_SITE_URL=http://localhost:3000
